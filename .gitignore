# =========================================================================
# CREST AI — PRODUCTION REPOSITORY EXCLUSION MATRIX (.gitignore)
# =========================================================================

# ── ENVIRONMENT CONFIGURATIONS & PRIVATE KEYS ──
# Prevents raw tokens or private client configurations from tracking online
.env
.env.local
.env.*.local
*.env
config.json
secrets.js

# ── OPERATING SYSTEM & SYSTEM LOG JUNK ──
# Prevents desktop caches and editor settings from messing up your commits
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.suo
*.swp

# ── RUNTIME PERFORMANCE BUFFERS & CACHES ──
# Proactively keeps local testing server or script caches hidden
__pycache__/
*.py[cod]
*$py.class
.venv
venv/
ENV/